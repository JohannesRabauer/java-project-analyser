# ===== Java Project Analyser Configuration =====

# --- Database ---
POSTGRES_DB=analyser
POSTGRES_USER=analyser
POSTGRES_PASSWORD=analyser

# --- Pipeline Model (bulk analysis at index time — can be cheap/local) ---
PIPELINE_MODEL_PROVIDER=ollama
PIPELINE_MODEL_NAME=llama3

# --- Query Model (on-demand reasoning at query time — can be high-quality) ---
QUERY_MODEL_PROVIDER=ollama
QUERY_MODEL_NAME=llama3

# --- Embedding Model ---
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL_NAME=nomic-embed-text

# --- OpenAI (only needed if using openai as provider) ---
# OPENAI_API_KEY=sk-...

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434

# --- MCP Stdio (set to true for IDE integration mode) ---
MCP_STDIO_ENABLED=false

# --- Workspace & Cache ---
WORKSPACE_PATH=./workspace
CACHE_PATH=./cache
