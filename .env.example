# ╔══════════════════════════════════════════════════════════════╗
# ║  Java Project Analyser — Configuration                      ║
# ║                                                              ║
# ║  Only 2 values required for the demo:                       ║
# ╚══════════════════════════════════════════════════════════════╝

# 1. The Java project to analyze (Git URL or local path)
PROJECT_URL=https://github.com/xdev-software/spring-data-eclipse-store

# 2. Your OpenAI API key
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────
# Optional: Advanced configuration (defaults work for most users)
# ──────────────────────────────────────────────────────────────

# Model selection (defaults to OpenAI gpt-4o-mini — fast and cheap)
# PIPELINE_MODEL_PROVIDER=openai
# PIPELINE_MODEL_NAME=gpt-4o-mini
# QUERY_MODEL_PROVIDER=openai
# QUERY_MODEL_NAME=gpt-4o-mini
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL_NAME=text-embedding-3-small

# Use Ollama instead (run: docker compose --profile ollama up)
# PIPELINE_MODEL_PROVIDER=ollama
# PIPELINE_MODEL_NAME=llama3
# OLLAMA_BASE_URL=http://ollama:11434
