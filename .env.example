# Copy this file to .env and adjust the values for your machine.

# QUARKUS_PROFILE: Active Quarkus runtime profile. Use local, openai, or anthropic.
QUARKUS_PROFILE=local

# POSTGRES_DB: Database name created inside the pgvector container.
POSTGRES_DB=analyser

# POSTGRES_USER: Database user used by Quarkus and Flyway.
POSTGRES_USER=analyser

# POSTGRES_PASSWORD: Database password used by Quarkus and Flyway.
POSTGRES_PASSWORD=analyser

# WORKSPACE_PATH: Host directory bind-mounted at /workspace for analysed projects.
WORKSPACE_PATH=./workspace

# CACHE_PATH: Host directory bind-mounted at /cache for generated reports and caches.
CACHE_PATH=./cache

# OLLAMA_BASE_URL: Ollama endpoint used by the local profile.
OLLAMA_BASE_URL=http://ollama:11434

# OPENAI_API_KEY: Required when QUARKUS_PROFILE=openai.
OPENAI_API_KEY=

# ANTHROPIC_API_KEY: Reserved for the anthropic profile.
ANTHROPIC_API_KEY=
